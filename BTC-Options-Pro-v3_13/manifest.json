{
  "manifest_version": 3,
  "name": "BTC Options Pro Analyzer v2",
  "version": "3.13.2",
  "description": "Binance 二元期权 4-Agent（v3.13.2: 纯剥头皮模式——执行周期(1M/5M)定方向，大周期(15M/30M)只作顺风/逆风加减分绝不否决；逆大周期照做但缩5M期限快进快出；不再被大周期锁死）",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "notifications",
    "alarms",
    "downloads"
  ],
  "host_permissions": [
    "https://api.binance.com/*",
    "https://stream.binance.com/*",
    "https://api.anthropic.com/*",
    "https://api.apikey.fun/*",
    "https://www.binance.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.binance.com/*"
      ],
      "js": [
        "winrate-calc.js",
        "storage-keys.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icon*.png"
      ],
      "matches": [
        "https://www.binance.com/*"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}