{
  "manifest_version": 3,
  "name": "BTC Options Pro Analyzer v2",
  "version": "3.16.3",
  "description": "Binance 二元期权 4-Agent（v3.16.3: 元裁判审计结果改为内联展示在「历史」标签(像旧版,不再弹窗),保留多条审计历史按时间与预测交错; v3.16.2 踏空审计维度; v3.16 修复趋势市晚入场/追涨杀跌; LLM主导+五本书心法+协作纠错）",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "notifications",
    "alarms",
    "downloads"
  ],
  "host_permissions": [
    "https://api.binance.com/*",
    "https://stream.binance.com/*",
    "https://api.anthropic.com/*",
    "https://api.apikey.fun/*",
    "https://www.binance.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.binance.com/*"
      ],
      "js": [
        "winrate-calc.js",
        "storage-keys.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icon*.png"
      ],
      "matches": [
        "https://www.binance.com/*"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}