{
  "manifest_version": 3,
  "name": "BTC Options Pro Analyzer v2",
  "version": "3.16.4",
  "description": "Binance 二元期权 4-Agent（v3.16.4: P0据审计——强ADX(≥30)追势撞超卖/超买且无回撤结束确认=观望(勿卖地板/买墙上),质疑师强制给基于K线的具体反驳(禁空评级,自动迁移);历史审计卡片默认折叠; LLM主导+五本书心法）",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "notifications",
    "alarms",
    "downloads"
  ],
  "host_permissions": [
    "https://api.binance.com/*",
    "https://stream.binance.com/*",
    "https://api.anthropic.com/*",
    "https://api.apikey.fun/*",
    "https://www.binance.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.binance.com/*"
      ],
      "js": [
        "winrate-calc.js",
        "storage-keys.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icon*.png"
      ],
      "matches": [
        "https://www.binance.com/*"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}