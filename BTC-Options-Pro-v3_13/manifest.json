{
  "manifest_version": 3,
  "name": "BTC Options Pro Analyzer v2",
  "version": "3.14.0",
  "description": "Binance 二元期权 4-Agent（v3.14: 架构转向LLM主导——规则引擎降为参考信号，方向/可否/期限由分析师·质疑师·裁判独立判断并相互纠错；代码只保留真死盘+保本线两道硬安全线）",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "notifications",
    "alarms",
    "downloads"
  ],
  "host_permissions": [
    "https://api.binance.com/*",
    "https://stream.binance.com/*",
    "https://api.anthropic.com/*",
    "https://api.apikey.fun/*",
    "https://www.binance.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.binance.com/*"
      ],
      "js": [
        "winrate-calc.js",
        "storage-keys.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icon*.png"
      ],
      "matches": [
        "https://www.binance.com/*"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}